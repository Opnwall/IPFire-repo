+class DDNSProviderAliDNS(DDNSProvider):
+	handle    = "alidns.aliyuncs.com"
+	name      = "Alibaba Cloud DNS"
+	website   = "https://www.alibabacloud.com/product/dns"
+	protocols = ("ipv6", "ipv4",)
+
+	url = "https://alidns.aliyuncs.com/"
+	can_remove_records = False
+	supports_token_auth = False
+
+	def update_protocol(self, proto):
+		record_type = self._record_type(proto)
+		domain, rr, record = self._get_record(record_type)
+
+		data = {
+			"RR"     : rr,
+			"Type"   : record_type,
+			"Value"  : self.get_address(proto),
+			"TTL"    : record.get("TTL", 600) if record else 600,
+			"Line"   : record.get("Line", "default") if record else "default",
+			"Status" : "Enable",
+		}
+
+		if record:
+			data["RecordId"] = record.get("RecordId")
+			self._send_request("UpdateDomainRecord", data)
+		else:
+			data["DomainName"] = domain
+			self._send_request("AddDomainRecord", data)
+
+	def _record_type(self, proto):
+		if proto == "ipv6":
+			return "AAAA"
+
+		return "A"
+
+	def _get_record(self, record_type):
+		cache_key = "alidns_record_%s" % record_type
+		if cache_key in self.settings:
+			return self.settings[cache_key]
+
+		for domain, rr in self._iter_domain_candidates():
+			try:
+				response = self._send_request("DescribeSubDomainRecords", {
+					"DomainName" : domain,
+					"SubDomain"  : self.hostname,
+					"Type"       : record_type,
+				})
+			except DDNSRequestError:
+				continue
+
+			records = response.get("DomainRecords", {}).get("Record", [])
+			if len(records) > 1:
+				raise DDNSRequestError(_("Alibaba Cloud DNS returned more than one %(type)s record for %(hostname)s") % {
+					"type"     : record_type,
+					"hostname" : self.hostname,
+				})
+
+			record = records[0] if records else None
+			self.settings[cache_key] = (domain, rr, record)
+
+			return self.settings[cache_key]
+
+		raise DDNSRequestError(_("Could not find Alibaba Cloud DNS zone for %s") % self.hostname)
+
+	def _iter_domain_candidates(self):
+		labels = self.hostname.split(".")
+		for i in range(0, len(labels) - 1):
+			domain = ".".join(labels[i:])
+			rr = ".".join(labels[:i]) or "@"
+
+			yield domain, rr
+
+	def _send_request(self, action, data=None):
+		if not self.username or not self.password:
+			raise DDNSConfigurationError
+
+		params = {
+			"Action"           : action,
+			"Version"          : "2015-01-09",
+			"Format"           : "JSON",
+			"AccessKeyId"      : self.username,
+			"SignatureMethod"  : "HMAC-SHA1",
+			"SignatureVersion" : "1.0",
+			"SignatureNonce"   : str(uuid.uuid4()),
+			"Timestamp"        : datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ"),
+		}
+
+		if data:
+			params.update(data)
+
+		params["Signature"] = self._sign(params)
+		url = "%s?%s" % (self.url, self._format_query_args(params))
+
+		response = self.send_request(url)
+		output = response.read().decode()
+
+		try:
+			payload = json.loads(output)
+		except ValueError:
+			raise DDNSUpdateError(_("Server response: %s") % output)
+
+		if payload.get("Code"):
+			code = payload.get("Code")
+			message = payload.get("Message", code)
+
+			if code in ("InvalidAccessKeyId.NotFound", "SignatureDoesNotMatch", "Forbidden.RAM"):
+				raise DDNSAuthenticationError(message)
+
+			raise DDNSRequestError(message)
+
+		return payload
+
+	def _sign(self, params):
+		query = self._format_query_args(params)
+		string_to_sign = "GET&%2F&%s" % urllib.parse.quote(query, safe="~")
+		key = "%s&" % self.password
+
+		return base64.b64encode(
+			hmac.new(key.encode(), string_to_sign.encode(), hashlib.sha1).digest()
+		).decode()
+
+	def _format_query_args(self, params):
+		args = []
+
+		for key in sorted(params):
+			args.append("%s=%s" % (
+				urllib.parse.quote(str(key), safe="~"),
+				urllib.parse.quote(str(params[key]), safe="~"),
+			))
+
+		return "&".join(args)
+
