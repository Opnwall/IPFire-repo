+class DDNSProviderCloudflare(DDNSProvider):
+	handle    = "cloudflare.com"
+	name      = "Cloudflare"
+	website   = "https://www.cloudflare.com/"
+	protocols = ("ipv6", "ipv4",)
+
+	url = "https://api.cloudflare.com/client/v4"
+	supports_token_auth = True
+
+	def update_protocol(self, proto):
+		record_type = self._record_type(proto)
+		record = self._get_record(record_type)
+
+		data = {
+			"type"    : record_type,
+			"name"    : self.hostname,
+			"content" : self.get_address(proto),
+			"ttl"     : record.get("ttl", 1) if record else 1,
+			"proxied" : record.get("proxied", False) if record else False,
+		}
+
+		if record:
+			url = "%s/zones/%s/dns_records/%s" % (self.url, self._get_zone_id(), record.get("id"))
+			self._send_request(url, method="PATCH", data=data)
+		else:
+			url = "%s/zones/%s/dns_records" % (self.url, self._get_zone_id())
+			self._send_request(url, method="POST", data=data)
+
+	def remove_protocol(self, proto):
+		record = self._get_record(self._record_type(proto))
+		if not record:
+			return
+
+		url = "%s/zones/%s/dns_records/%s" % (self.url, self._get_zone_id(), record.get("id"))
+		self._send_request(url, method="DELETE")
+
+	def _record_type(self, proto):
+		if proto == "ipv6":
+			return "AAAA"
+
+		return "A"
+
+	def _get_zone_id(self):
+		zone_id = self.get("zone_id")
+		if zone_id:
+			return zone_id
 
+		labels = self.hostname.split(".")
+		for i in range(0, len(labels) - 1):
+			zone = ".".join(labels[i:])
+			url = "%s/zones" % self.url
+			response = self._send_request(url, data={
+				"name"   : zone,
+				"status" : "active",
+			})
 
+			results = response.get("result", [])
+			if results:
+				zone_id = results[0].get("id")
+				self.settings["zone_id"] = zone_id
+
+				return zone_id
+
+		raise DDNSRequestError(_("Could not find Cloudflare zone for %s") % self.hostname)
+
+	def _get_record(self, record_type):
+		cache_key = "cloudflare_record_%s" % record_type
+		if cache_key in self.settings:
+			return self.settings[cache_key]
+
+		url = "%s/zones/%s/dns_records" % (self.url, self._get_zone_id())
+		response = self._send_request(url, data={
+			"type" : record_type,
+			"name" : self.hostname,
+		})
+
+		results = response.get("result", [])
+		if len(results) > 1:
+			raise DDNSRequestError(_("Cloudflare returned more than one %(type)s record for %(hostname)s") % {
+				"type"     : record_type,
+				"hostname" : self.hostname,
+			})
+
+		record = results[0] if results else None
+		self.settings[cache_key] = record
+
+		return record
+
+	def _send_request(self, url, method="GET", data=None):
+		if not self.token:
+			raise DDNSConfigurationError
+
+		headers = {
+			"Authorization" : "Bearer %s" % self.token,
+			"Accept"        : "application/json",
+		}
+
+		if method in ("POST", "PATCH"):
+			headers["Content-Type"] = "application/json"
+			data = json.dumps(data).encode()
+
+		response = self.send_request(url, method=method, data=data, headers=headers)
+		output = response.read().decode()
+
+		try:
+			payload = json.loads(output)
+		except ValueError:
+			raise DDNSUpdateError(_("Server response: %s") % output)
+
+		if payload.get("success"):
+			return payload
+
+		errors = payload.get("errors", [])
+		message = ", ".join([e.get("message", "") for e in errors if e.get("message")])
+
+		if response.code in (401, 403):
+			raise DDNSAuthenticationError(message)
+		elif response.code == 429:
+			raise DDNSTooManyRequests(message)
+		elif response.code >= 500:
+			raise DDNSInternalServerError(message)
+
+		raise DDNSUpdateError(message or _("Cloudflare API request failed"))
+
