+class DDNSProviderDNSPodTencentCloud(DDNSProvider):
+	handle    = "dnspod.tencentcloudapi.com"
+	name      = "Tencent Cloud DNSPod"
+	website   = "https://www.tencentcloud.com/products/dnspod"
+	protocols = ("ipv6", "ipv4",)
+
+	url = "https://dnspod.intl.tencentcloudapi.com/"
+	can_remove_records = False
+	supports_token_auth = False
+
+	def update_protocol(self, proto):
+		record_type = self._record_type(proto)
+		domain, subdomain, record = self._get_record(record_type)
+
+		data = {
+			"Domain"     : domain,
+			"SubDomain"  : subdomain,
+			"RecordType" : record_type,
+			"RecordLine" : record.get("Line", "Default") if record else "Default",
+			"Value"      : self.get_address(proto),
+			"TTL"        : record.get("TTL", 600) if record else 600,
+		}
+
+		if record:
+			data["RecordId"] = record.get("RecordId")
+			self._send_request("ModifyRecord", data)
+		else:
+			self._send_request("CreateRecord", data)
+
+	def _record_type(self, proto):
+		if proto == "ipv6":
+			return "AAAA"
+
+		return "A"
+
+	def _get_record(self, record_type):
+		cache_key = "dnspod_record_%s" % record_type
+		if cache_key in self.settings:
+			return self.settings[cache_key]
+
+		for domain, subdomain in self._iter_domain_candidates():
+			try:
+				response = self._send_request("DescribeRecordList", {
+					"Domain"     : domain,
+					"Subdomain"  : subdomain,
+					"RecordType" : record_type,
+				})
+			except DDNSRequestError:
+				continue
+
+			records = response.get("Response", {}).get("RecordList", [])
+			if len(records) > 1:
+				raise DDNSRequestError(_("Tencent Cloud DNSPod returned more than one %(type)s record for %(hostname)s") % {
+					"type"     : record_type,
+					"hostname" : self.hostname,
+				})
+
+			record = records[0] if records else None
+			self.settings[cache_key] = (domain, subdomain, record)
+
+			return self.settings[cache_key]
+
+		raise DDNSRequestError(_("Could not find Tencent Cloud DNSPod zone for %s") % self.hostname)
+
+	def _iter_domain_candidates(self):
+		labels = self.hostname.split(".")
+		for i in range(0, len(labels) - 1):
+			domain = ".".join(labels[i:])
+			subdomain = ".".join(labels[:i]) or "@"
+
+			yield domain, subdomain
+
+	def _send_request(self, action, data=None):
+		if not self.username or not self.password:
+			raise DDNSConfigurationError
+
+		data = data or {}
+		body = json.dumps(data).encode()
+		now = datetime.datetime.now(datetime.timezone.utc)
+		timestamp = int(now.timestamp())
+		date = now.strftime("%Y-%m-%d")
+		headers = self._make_headers(action, body, timestamp, date)
+
+		response = self.send_request(self.url, method="POST", data=body, headers=headers)
+		output = response.read().decode()
+
+		try:
+			payload = json.loads(output)
+		except ValueError:
+			raise DDNSUpdateError(_("Server response: %s") % output)
+
+		error = payload.get("Response", {}).get("Error")
+		if error:
+			code = error.get("Code")
+			message = error.get("Message", code)
+
+			if code and ("AuthFailure" in code or "UnauthorizedOperation" in code):
+				raise DDNSAuthenticationError(message)
+
+			raise DDNSRequestError(message)
+
+		return payload
+
+	def _make_headers(self, action, body, timestamp, date):
+		service = "dnspod"
+		host = "dnspod.intl.tencentcloudapi.com"
+		content_type = "application/json; charset=utf-8"
+		algorithm = "TC3-HMAC-SHA256"
+		credential_scope = "%s/%s/tc3_request" % (date, service)
+		signed_headers = "content-type;host"
+
+		canonical_request = "\n".join((
+			"POST",
+			"/",
+			"",
+			"content-type:%s\nhost:%s\n" % (content_type, host),
+			signed_headers,
+			hashlib.sha256(body).hexdigest(),
+		))
+
+		string_to_sign = "\n".join((
+			algorithm,
+			str(timestamp),
+			credential_scope,
+			hashlib.sha256(canonical_request.encode()).hexdigest(),
+		))
+
+		secret_date = self._hmac_sha256(("TC3%s" % self.password).encode(), date)
+		secret_service = self._hmac_sha256(secret_date, service)
+		secret_signing = self._hmac_sha256(secret_service, "tc3_request")
+		signature = hmac.new(secret_signing, string_to_sign.encode(), hashlib.sha256).hexdigest()
+
+		return {
+			"Authorization"  : "%s Credential=%s/%s, SignedHeaders=%s, Signature=%s" % (
+				algorithm, self.username, credential_scope, signed_headers, signature,
+			),
+			"Content-Type"   : content_type,
+			"Host"           : host,
+			"X-TC-Action"    : action,
+			"X-TC-Timestamp" : str(timestamp),
+			"X-TC-Version"   : "2021-03-23",
+		}
+
+	def _hmac_sha256(self, key, message):
+		return hmac.new(key, message.encode(), hashlib.sha256).digest()
+
